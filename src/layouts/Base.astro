---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  theme?: 'light' | 'dark';
  bgColor?: string;
}
const { title, theme = 'light', bgColor = '#ECE9DF' } = Astro.props;
---
<!doctype html>
<html lang="en" style={`background:${bgColor}`}>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title} — VolnLabs</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400..700&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  <style is:global>
    html, body { margin: 0; padding: 0; }
    *, *::before, *::after { box-sizing: border-box; }
    ::selection { background: #054FF0; color: #F9F8F3; }
    a { color: inherit; }
  </style>
<script is:inline>
  (function () {
    const BASE_SCALE = 0.68;

    function fit() {
      const scale = Math.min(
        BASE_SCALE * Math.max(window.innerWidth / 1200, 1),
        1.12
      );

      document.documentElement.style.zoom = scale;
    }

    fit();
    window.addEventListener("resize", fit, { passive: true });
  })();
</script>
</head>
<body style={`font-family:'Space Mono', monospace; -webkit-font-smoothing:antialiased; background:${bgColor}; color:#0a0a0b; overflow-x:hidden;`}>
  <Nav theme={theme} />
  <slot />
  <Footer />
</body>
</html>
