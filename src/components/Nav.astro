---
interface Props {
  theme?: 'light' | 'dark';
}
const { theme = 'light' } = Astro.props;
---
<nav id="nav" data-theme={theme}>
  <div id="nav-inner">
    <a id="nav-logo" href="/">volnlabs<span class="dot">.</span></a>
    <div id="nav-pill">
      <a href="/vision" class="nav-link">Vision</a>
      <a href="/research" class="nav-link">Research</a>
      <a href="/publications" class="nav-link">Publications</a>
      <a href="/blog" class="nav-link">Blog</a>
      <a href="/opensource" class="nav-link">Open&nbsp;Source</a>
      <a href="/people" class="nav-link">People</a>
      <a href="/contact" class="nav-cta">Contact</a>
    </div>
  </div>
</nav>

<style>
  #nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 95;
    font-family: 'Bricolage Grotesque', sans-serif;
    background: transparent;
    pointer-events: none;
  }
  #nav-inner {
    width: 100%;
    padding-left: max(32px, calc((100% - 1200px) / 2 + 32px));
    padding-right: 28px;
    height: 96px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }
  #nav-logo {
    font-family: 'Bricolage Grotesque', sans-serif;
    font-weight: 700;
    font-size: 23px;
    line-height: 1;
    letter-spacing: -0.03em;
    text-decoration: none;
    flex: none;
    white-space: nowrap;
    transition: opacity 0.3s ease;
    pointer-events: auto;
  }
  #nav[data-theme="dark"] #nav-logo { color: #F9F8F3; }
  #nav[data-theme="light"] #nav-logo { color: #0a0a0b; }
  #nav-logo.scrolled { opacity: 0; pointer-events: none; }
  .dot { color: #054FF0; }
  #nav-pill {
    display: flex;
    align-items: center;
    gap: 2px;
    background: #F9F8F3;
    border-radius: 999px;
    padding: 6px;
    box-shadow: 0 10px 28px rgba(0,0,0,0.16);
    border: 1px solid rgba(10,10,11,0.06);
    pointer-events: auto;
  }
  .nav-link {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    color: rgba(10,10,11,0.62);
    padding: 8px 13px;
    border-radius: 999px;
  }
  .nav-link:hover { color: #0a0a0b; background: rgba(10,10,11,0.05); }
  .nav-cta {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    color: #F9F8F3;
    background: #054FF0;
    border-radius: 999px;
    padding: 8px 16px;
  }
  .nav-cta:hover { background: #043bc0; }
  @media (max-width: 680px) {
    #nav-inner {
      justify-content: center;
      padding-left: 10px;
      padding-right: 10px;
    }
    #nav-logo { display: none; }
    #nav-pill {
      max-width: calc(100vw - 20px);
      overflow-x: auto;
      scrollbar-width: none;
      gap: 0;
      padding: 5px;
    }
    #nav-pill::-webkit-scrollbar { display: none; }
    .nav-link, .nav-cta {
      font-size: 10px;
      padding: 7px 10px;
      letter-spacing: 0.06em;
    }
  }
</style>

<script>
  const logo = document.getElementById('nav-logo');
  if (logo) {
    window.addEventListener('scroll', () => {
      logo.classList.toggle('scrolled', window.scrollY > 28);
    }, { passive: true });
  }
</script>
