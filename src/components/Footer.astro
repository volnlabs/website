<footer>
  <div class="footer-inner">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="footer-logo">volnLabs<span style="color:#054FF0;">.</span></div>
        <div class="footer-tagline">Building the foundations of adaptive intelligent systems.</div>
        <a href="/contact" class="footer-cta">Start a collaboration →</a>
      </div>
      <div>
        <div class="col-label">Explore</div>
        <div class="col-links">
          <a href="/vision">Vision</a>
          <a href="/research">Research</a>
          <a href="/publications">Publications</a>
        </div>
      </div>
      <div>
        <div class="col-label">Lab</div>
        <div class="col-links">
          <a href="/opensource">Open Source</a>
          <a href="/people">People</a>
          <a href="/contact">Contact</a>
        </div>
      </div>
      <div>
        <div class="col-label">Connect</div>
        <div class="col-links">
          <a href="mailto:research@volnlabs.com">research@volnlabs.com</a>
          <a href="https://github.com/volnlabs" target="_blank" rel="noopener">github.com/volnlabs</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© 2026 VolnLabs · volnlabs.com</span>
      <span>The safety layer between code and motors.</span>
    </div>
  </div>
</footer>

<style>
  footer {
    background: #0a0a0b;
    color: #F9F8F3;
    font-family: 'Space Mono', monospace;
  }
  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 72px 32px 36px;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: 40px;
  }
  .footer-logo {
    font-family: 'Bricolage Grotesque', sans-serif;
    font-size: 34px;
    line-height: 1;
  }
  .footer-tagline {
    font-family: 'Bricolage Grotesque', sans-serif;
    font-style: italic;
    font-size: 19px;
    line-height: 1.35;
    color: rgba(249,248,243,0.72);
    margin-top: 14px;
    max-width: 30ch;
  }
  .footer-cta {
    display: inline-block;
    margin-top: 22px;
    text-decoration: none;
    color: #0a0a0b;
    background: #DCFC73;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 11px 18px;
    border-radius: 999px;
  }
  .col-label {
    font-size: 10.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(249,248,243,0.4);
  }
  .col-links {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 16px;
    font-size: 13px;
  }
  .col-links a {
    text-decoration: none;
    color: rgba(249,248,243,0.78);
  }
  .col-links a:hover { color: #F9F8F3; }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 48px;
    padding-top: 22px;
    border-top: 1px solid rgba(249,248,243,0.14);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: rgba(249,248,243,0.45);
  }
</style>
