---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---
<Base title="Blog" description="Notes, engineering writing, and ideas from the VolnLabs team on adaptive runtimes and autonomous machines." bgColor="#F9F8F3">

  <!-- HEADER -->
  <section style="position:relative; overflow:hidden; border-bottom:1px solid rgba(10,10,11,0.08);">
    <div style="position:absolute; top:-200px; left:-140px; width:540px; height:540px; border-radius:50%; background:radial-gradient(circle at 50% 50%, rgba(221,231,254,0.9) 0%, rgba(221,231,254,0) 68%); pointer-events:none;"></div>
    <div class="blogsec" style="max-width:1200px; margin:0 auto; padding:80px 32px 60px; position:relative;">
      <div style="font-size:11px; letter-spacing:0.2em; text-transform:uppercase; color:#054FF0;">Blog</div>
      <h1 style="font-family:'Bricolage Grotesque', sans-serif; font-weight:600; font-size:clamp(34px, 5.4vw, 68px); line-height:1.0; letter-spacing:-0.015em; margin:18px 0 0;">Notes from the lab<span style="color:#054FF0;">.</span></h1>
      <p style="font-size:15px; line-height:1.75; color:rgba(10,10,11,0.7); max-width:56ch; margin:22px 0 0;">Engineering writing and short essays on adaptive runtimes, safety, and the systems behind autonomous machines.</p>
    </div>
  </section>

  <!-- LIST -->
  <section style="background:#F9F8F3;">
    <div class="blogsec" style="max-width:1200px; margin:0 auto; padding:28px 32px 84px;">
      <div style="border-top:1px solid rgba(10,10,11,0.16);">
        {posts.map(post => (
          <a href={`/blog/${post.id}`} class="blog-row" style="display:grid; grid-template-columns:130px 1fr 130px; gap:24px; align-items:center; padding:28px 0; border-bottom:1px solid rgba(10,10,11,0.1); text-decoration:none; color:inherit;">
            <div style="font-size:13px; color:rgba(10,10,11,0.45);">{fmt(post.data.date)}</div>
            <div>
              <div style="font-family:'Bricolage Grotesque', sans-serif; font-size:24px; line-height:1.2;">{post.data.title}</div>
              <div style="font-size:13px; color:rgba(10,10,11,0.6); margin-top:8px; line-height:1.6; max-width:64ch;">{post.data.description}</div>
            </div>
            <div style="justify-self:end; font-size:10.5px; letter-spacing:0.08em; text-transform:uppercase; color:#054FF0; background:#DDE7FE; border-radius:999px; padding:7px 14px;">{post.data.tag}</div>
          </a>
        ))}
      </div>
      {posts.length === 0 && (
        <p style="font-size:13px; color:rgba(10,10,11,0.55); margin:28px 0 0;">No posts yet.</p>
      )}
    </div>
  </section>

<style>
  .blog-row:hover { background: rgba(10,10,11,0.02); }
  @media (max-width: 640px) {
    .blog-row { grid-template-columns: 1fr !important; gap: 8px !important; align-items: start !important; }
    .blogsec { padding-left: 20px !important; padding-right: 20px !important; }
  }
</style>
</Base>
