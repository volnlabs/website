---
import Base from '../layouts/Base.astro';
---
<Base title="Runtime for autonomous machines" description="VolnLabs builds the runtime for autonomous machines and robots — systems that learn and adapt at execution time instead of relying on static code. Research, publications, and open source in adaptive intelligence." theme="dark" bgColor="#ECE9DF">

  <!-- HERO -->
  <section class="hero" style="position:relative; overflow:hidden; min-height:100vh; display:flex; align-items:center; background:#100F0D; color:#F9F8F3;">
    <div class="hero-canvas" style="position:absolute; top:0; right:0; bottom:0; width:56%; overflow:hidden;">
      <canvas id="topo-canvas" style="position:absolute; inset:0; width:100%; height:100%; display:block;"></canvas>
      <div class="hero-fade" style="position:absolute; inset:0; background:linear-gradient(90deg, #100F0D 0%, rgba(16,15,13,0.7) 22%, rgba(16,15,13,0) 55%); pointer-events:none;"></div>
      <div style="position:absolute; right:28px; bottom:22px; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:rgba(236,233,223,0.5);">[ Signal map · adaptive runtime ]</div>
    </div>
    <div class="hero-content" style="position:relative; z-index:2; width:100%; max-width:1200px; margin:0 auto; padding:120px 32px 88px;">
      <div class="hero-text" style="width:46%; min-width:380px;">
        <h1 style="font-family:'Bricolage Grotesque', sans-serif; font-weight:600; font-size:clamp(36px, 5vw, 65px); line-height:1.0; letter-spacing:-0.015em; margin:0; color:#F9F8F3;">Reimagining adaptive intelligence, from first principles<span style="color:#054FF0;">.</span></h1>
        <p style="font-size:14.5px; line-height:1.8; color:rgba(249,248,243,0.68); max-width:46ch; margin:26px 0 0;">VolnLabs studies how intelligent behavior can be represented, executed, and safely evolved — across neuroscience, operating systems, distributed systems, and robotics. One signal, passed up the stack.</p>
        <div style="display:flex; gap:12px; flex-wrap:wrap; margin-top:30px;">
          <a href="/research" class="btn-primary">Explore research →</a>
          <a href="/vision" class="btn-ghost">Read the vision</a>
        </div>
        <div style="display:inline-flex; align-items:center; gap:10px; margin-top:48px; font-size:10.5px; letter-spacing:0.14em; text-transform:uppercase; color:rgba(249,248,243,0.6); border:1px solid rgba(249,248,243,0.22); padding:10px 16px;">
          <span style="width:6px; height:6px; border-radius:999px; background:#054FF0; display:inline-block;"></span>
          No black boxes. Just systems that listen, learn, and adapt.
        </div>
      </div>
    </div>
  </section>

  <!-- MISSION -->
  <section style="background:#ECE9DF; border-top:1px solid rgba(10,10,11,0.1);">
    <div style="max-width:1200px; margin:0 auto; padding:88px 32px;">
      <div style="font-size:11px; letter-spacing:0.2em; text-transform:uppercase; color:#054FF0;">[ 01 ] — Mission</div>
      <div class="responsive-split" style="display:grid; grid-template-columns:1.1fr 0.9fr; gap:56px; margin-top:24px; align-items:start;">
        <h2 style="font-family:'Bricolage Grotesque', sans-serif; font-weight:600; font-size:clamp(26px, 3.6vw, 41px); line-height:1.06; letter-spacing:-0.01em; margin:0;">Today's intelligent systems are fragmented. We believe they are parts of the same problem.</h2>
        <div>
          <div style="border-top:1px solid rgba(10,10,11,0.18);">
            <div style="display:flex; justify-content:space-between; padding:13px 0; border-bottom:1px solid rgba(10,10,11,0.12); font-size:13px;"><span style="color:rgba(10,10,11,0.55);">Artificial intelligence</span><span>learns.</span></div>
            <div style="display:flex; justify-content:space-between; padding:13px 0; border-bottom:1px solid rgba(10,10,11,0.12); font-size:13px;"><span style="color:rgba(10,10,11,0.55);">Operating systems</span><span>execute.</span></div>
            <div style="display:flex; justify-content:space-between; padding:13px 0; border-bottom:1px solid rgba(10,10,11,0.12); font-size:13px;"><span style="color:rgba(10,10,11,0.55);">Robots</span><span>act in the world.</span></div>
            <div style="display:flex; justify-content:space-between; padding:13px 0; border-bottom:1px solid rgba(10,10,11,0.12); font-size:13px;"><span style="color:rgba(10,10,11,0.55);">Distributed systems</span><span>coordinate.</span></div>
            <div style="display:flex; justify-content:space-between; padding:13px 0; border-bottom:1px solid rgba(10,10,11,0.12); font-size:13px;"><span style="color:rgba(10,10,11,0.55);">Neuroscience</span><span>studies biology.</span></div>
          </div>
          <a href="/vision" style="display:inline-block; margin-top:20px; font-size:11px; letter-spacing:0.1em; text-transform:uppercase; text-decoration:none; color:#054FF0;">Read our full vision →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FLAGSHIP PROGRAM -->
  <section style="background:#E5E1D5; border-top:1px solid rgba(10,10,11,0.08);">
    <div style="max-width:1200px; margin:0 auto; padding:88px 32px;">
      <div style="display:flex; justify-content:space-between; align-items:flex-end; gap:24px; flex-wrap:wrap;">
        <div>
          <div style="font-size:11px; letter-spacing:0.2em; text-transform:uppercase; color:#054FF0;">[ 02 ] — Flagship Program</div>
          <h2 style="font-family:'Bricolage Grotesque', sans-serif; font-weight:600; font-size:clamp(27px, 4vw, 46px); line-height:1.0; margin:16px 0 0;">One program. Total focus.</h2>
        </div>
        <a href="/research" class="btn-outline-dark">Explore AxiomOS →</a>
      </div>
      <a href="/research" class="programs-card responsive-grid" style="display:grid; grid-template-columns:1fr 1fr; margin-top:36px; background:#F4F1E8; border:1px solid rgba(10,10,11,0.12);">
        <div style="padding:40px; border-right:1px solid rgba(10,10,11,0.1);">
          <div style="display:flex; align-items:center; justify-content:space-between;">
            <span style="font-size:10.5px; letter-spacing:0.16em; text-transform:uppercase; color:rgba(10,10,11,0.45);">Execute intelligence</span>
            <span style="width:12px; height:12px; border-radius:999px; background:#DCFC73;"></span>
          </div>
          <div style="font-family:'Bricolage Grotesque', sans-serif; font-size:clamp(41px, 6vw, 65px); line-height:0.95; margin-top:26px;">AxiomOS</div>
          <div style="font-family:'Bricolage Grotesque', sans-serif; font-style:italic; font-size:22px; line-height:1.3; color:rgba(10,10,11,0.7); margin-top:18px;">Behavior that evolves without losing safety.</div>
        </div>
        <div style="padding:40px; display:flex; flex-direction:column; justify-content:space-between; min-height:240px;">
          <p style="font-size:14px; line-height:1.8; color:rgba(10,10,11,0.7); margin:0;">Adaptive systems must stay understandable even as they evolve. AxiomOS treats behaviors as hot-swappable units — authenticated, analyzed, and admitted before they ever reach hardware.</p>
          <div style="display:flex; align-items:center; justify-content:space-between; gap:16px; flex-wrap:wrap; margin-top:28px;">
            <div style="display:flex; gap:8px; flex-wrap:wrap; font-size:10px; letter-spacing:0.12em; text-transform:uppercase;">
              <span style="border:1px solid rgba(10,10,11,0.2); padding:6px 12px; color:rgba(10,10,11,0.6);">Real-time kernel</span>
              <span style="border:1px solid rgba(10,10,11,0.2); padding:6px 12px; color:rgba(10,10,11,0.6);">Hot-swap units</span>
            </div>
            <span style="font-size:11px; letter-spacing:0.1em; text-transform:uppercase; color:#054FF0;">Explore the stack →</span>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- VERIFY -->
  <section style="position:relative; background:#100F0D; color:#F9F8F3; overflow:hidden;">
    <div style="position:absolute; top:0; right:0; width:46%; height:100%; background-image:radial-gradient(rgba(249,248,243,0.16) 1px, transparent 1px); background-size:14px 14px; opacity:0.5; pointer-events:none;"></div>
    <div style="position:relative; max-width:1200px; margin:0 auto; padding:88px 32px 44px;">
      <div style="display:flex; justify-content:space-between; align-items:center; gap:48px; flex-wrap:wrap;">
        <div style="max-width:38ch;">
          <div style="font-size:11px; letter-spacing:0.2em; text-transform:uppercase; color:#DCFC73;">[ 03 ] — AxiomOS</div>
          <h2 style="font-family:'Bricolage Grotesque', sans-serif; font-weight:600; font-size:clamp(29px, 4.4vw, 51px); line-height:1.0; margin:16px 0 0;">Behavior you can verify.</h2>
          <p style="font-size:14px; line-height:1.8; color:rgba(249,248,243,0.68); margin:18px 0 0; max-width:46ch;">Adaptive systems must stay understandable even as they evolve. AxiomOS treats behaviors as hot-swappable units — authenticated, analyzed, and admitted before they ever reach hardware.</p>
        </div>
        <a href="/research" class="btn-outline-light">Explore the stack →</a>
      </div>
      <div style="margin-top:64px; padding-top:24px; border-top:1px solid rgba(249,248,243,0.16); display:flex; gap:48px; flex-wrap:wrap;">
        <div style="flex:1; min-width:200px;">
          <div style="font-family:'Bricolage Grotesque', sans-serif; font-size:40px; line-height:1;">99 ms</div>
          <div style="font-size:10.5px; letter-spacing:0.14em; text-transform:uppercase; color:rgba(249,248,243,0.45); margin-top:8px;">Boot to init · Raspberry Pi 5</div>
        </div>
        <div style="flex:1; min-width:200px;">
          <div style="font-family:'Bricolage Grotesque', sans-serif; font-size:40px; line-height:1;">211 ns</div>
          <div style="font-size:10.5px; letter-spacing:0.14em; text-transform:uppercase; color:rgba(249,248,243,0.45); margin-top:8px;">Hardware entry to BPF · average</div>
        </div>
        <div style="flex:1; min-width:200px;">
          <div style="font-family:'Bricolage Grotesque', sans-serif; font-size:40px; line-height:1; color:#DCFC73;">&lt;1 &micro;s</div>
          <div style="font-size:10.5px; letter-spacing:0.14em; text-transform:uppercase; color:rgba(249,248,243,0.45); margin-top:8px;">BPF program load · average</div>
        </div>
      </div>
      <a href="/benchmarks" style="display:inline-block; margin-top:30px; color:#DCFC73; text-decoration:none; font-size:10.5px; letter-spacing:0.12em; text-transform:uppercase;">Review benchmark methodology →</a>
    </div>
  </section>

  <!-- PUBLICATIONS + OPEN SOURCE -->
  <section style="background:#ECE9DF;">
    <div class="responsive-grid" style="max-width:1200px; margin:0 auto; padding:88px 32px; display:grid; grid-template-columns:1fr 1fr; gap:18px;">
      <a href="/publications" class="card-light" style="background:#F4F1E8; border:1px solid rgba(10,10,11,0.12); padding:32px; display:flex; flex-direction:column; min-height:260px;">
        <div style="font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#054FF0;">[ 04 ] — Publications</div>
        <h3 style="font-family:'Bricolage Grotesque', sans-serif; font-weight:600; font-size:34px; line-height:1.02; margin:14px 0 0;">Selected &amp; forthcoming papers.</h3>
        <p style="font-size:13.5px; line-height:1.7; color:rgba(10,10,11,0.68); margin:14px 0 0;">Systems, architectures, experiments and prototypes — released following review.</p>
        <div style="margin-top:auto; padding-top:20px; font-size:11px; letter-spacing:0.1em; text-transform:uppercase; color:#054FF0;">View publications →</div>
      </a>
      <a href="/opensource" class="card-dark-hover" style="background:#100F0D; padding:32px; display:flex; flex-direction:column; min-height:260px;">
        <div style="font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#DCFC73;">[ 05 ] — Open Source</div>
        <h3 style="font-family:'Bricolage Grotesque', sans-serif; font-weight:600; font-size:34px; line-height:1.02; margin:14px 0 0; color:#F9F8F3;">Research should be reproducible.</h3>
        <p style="font-size:13.5px; line-height:1.7; color:rgba(249,248,243,0.7); margin:14px 0 0;">Selected projects are released open source following publication or IP review.</p>
        <div style="margin-top:auto; padding-top:20px; font-size:11px; letter-spacing:0.1em; text-transform:uppercase; color:#DCFC73;">Browse repositories →</div>
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section style="background:#E5E1D5; border-top:1px solid rgba(10,10,11,0.1);">
    <div style="max-width:1200px; margin:0 auto; padding:84px 32px; display:flex; justify-content:space-between; align-items:center; gap:40px; flex-wrap:wrap;">
      <div>
        <h2 style="font-family:'Bricolage Grotesque', sans-serif; font-weight:600; font-size:clamp(26px, 4vw, 44px); line-height:1.02; margin:0; max-width:18ch;">If our questions are your questions, let's talk.</h2>
        <p style="font-size:14px; line-height:1.7; color:rgba(10,10,11,0.68); margin:16px 0 0; max-width:48ch;">We welcome collaboration with researchers, engineers, universities and industry partners working on adaptive intelligent systems.</p>
      </div>
      <a href="/contact" class="btn-cta-dark">research@volnlabs.com →</a>
    </div>
  </section>

</Base>

<style>
  .btn-primary { text-decoration:none; background:#054FF0; color:#F9F8F3; font-size:12px; letter-spacing:0.06em; text-transform:uppercase; padding:14px 24px; }
  .btn-primary:hover { background:#043bc0; }
  .btn-ghost { text-decoration:none; background:transparent; border:1px solid rgba(249,248,243,0.32); color:#F9F8F3; font-size:12px; letter-spacing:0.06em; text-transform:uppercase; padding:14px 24px; }
  .btn-ghost:hover { border-color:#F9F8F3; }
  .btn-outline-dark { text-decoration:none; color:#0a0a0b; border:1px solid rgba(10,10,11,0.28); padding:12px 18px; font-size:11px; letter-spacing:0.1em; text-transform:uppercase; }
  .btn-outline-dark:hover { border-color:#0a0a0b; }
  .btn-outline-light { flex:none; text-decoration:none; border:1px solid rgba(249,248,243,0.35); color:#F9F8F3; font-size:11px; letter-spacing:0.12em; text-transform:uppercase; padding:15px 24px; }
  .btn-outline-light:hover { border-color:#F9F8F3; background:rgba(249,248,243,0.06); }
  .btn-cta-dark { flex:none; text-decoration:none; background:#100F0D; color:#F9F8F3; font-size:12px; letter-spacing:0.06em; text-transform:uppercase; padding:16px 28px; }
  .btn-cta-dark:hover { background:#054FF0; }
  .programs-card { text-decoration:none; color:inherit; }
  .programs-card:hover { background:#fff !important; }
  @media (max-width: 1024px) {
    .hero { min-height: 92vh; align-items: flex-start; }
    .hero-canvas { width: 100% !important; }
    .hero-fade { background: linear-gradient(180deg, #100F0D 0%, #100F0D 34%, rgba(16,15,13,0.55) 60%, rgba(16,15,13,0) 100%) !important; }
    .hero-content { padding-top: 132px !important; padding-bottom: 80px !important; }
    .hero-text { width: 100% !important; min-width: 0 !important; max-width: 600px; }
  }
  @media (max-width: 640px) {
    .hero { min-height: 90vh; }
    .hero-content { padding-left: 20px !important; padding-right: 20px !important; }
    .programs-card { grid-template-columns: 1fr !important; }
  }
  .card-light { text-decoration:none; color:inherit; }
  .card-light:hover { background:#fff !important; }
  .card-dark-hover { text-decoration:none; color:inherit; }
  .card-dark-hover:hover { opacity:0.94; }
</style>

<script>
  (function () {
    const cv = document.getElementById('topo-canvas');
    if (!cv) return;
    const ctx = cv.getContext('2d');
    function draw() {
      const rect = cv.getBoundingClientRect();
      if (rect.width < 2 || rect.height < 2) return;
      const dpr = Math.min(2, window.devicePixelRatio || 1);
      cv.width = Math.round(rect.width * dpr);
      cv.height = Math.round(rect.height * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      const w = rect.width, h = rect.height;
      ctx.clearRect(0, 0, w, h);
      const cx = w * 0.52, cy = h * 0.48;
      const R = Math.min(w * 0.82, h * 0.72);
      const N = 34;
      for (let li = 0; li < N; li++) {
        const L = li / (N - 1);
        ctx.beginPath();
        const steps = 200;
        for (let s = 0; s <= steps; s++) {
          const th = (s / steps) * Math.PI * 2;
          let warp = 0;
          warp += Math.sin(th * 2 + L * 3.1) * 0.17;
          warp += Math.sin(th * 3 - L * 4.0 + 1.3) * 0.10;
          warp += Math.sin(th * 5 + L * 2.2 + 0.7) * 0.05;
          warp += Math.sin(th * 7 - L * 1.5 + 2.1) * 0.025;
          const rr = R * (0.10 + 0.92 * L) * (1 + warp * 0.55);
          const ox = cx + (L - 0.5) * w * 0.12;
          const oy = cy + (L - 0.5) * h * 0.05;
          const x = ox + Math.cos(th) * rr * 1.04;
          const y = oy + Math.sin(th) * rr * 0.80;
          s === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
        }
        ctx.closePath();
        const accent = (li % 8 === 3);
        ctx.strokeStyle = accent ? 'rgba(91,134,246,0.5)' : `rgba(214,208,191,${0.08 + 0.28 * L})`;
        ctx.lineWidth = accent ? 1.2 : 0.8;
        ctx.stroke();
      }
    }
    new ResizeObserver(draw).observe(cv);
    document.fonts.ready.then(draw);
    requestAnimationFrame(draw);
  })();
</script>
