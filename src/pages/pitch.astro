---
import Base from '../layouts/Base.astro';

const pdf = '/pitch-deck.pdf';
---
<Base title="Pitch Deck" description="VolnLabs pitch deck." bgColor="#0A0A0B" theme="dark">

  <section style="max-width:1200px; margin:0 auto; padding:110px 32px 16px;">
    <div style="font-size:11px; letter-spacing:0.2em; text-transform:uppercase; color:#6FA0FF;">Pitch Deck</div>
    <h1 style="font-family:'Bricolage Grotesque', sans-serif; font-weight:600; font-size:clamp(28px, 4vw, 44px); line-height:1.0; letter-spacing:-0.015em; margin:14px 0 0; color:#F9F8F3;">VolnLabs<span style="color:#6FA0FF;">.</span></h1>
    <a href={pdf} target="_blank" rel="noopener" style="display:inline-block; margin-top:22px; font-size:13px; color:#0A0A0B; background:#6FA0FF; border-radius:999px; padding:11px 22px; text-decoration:none; font-weight:500;">Open in new tab ↗</a>
  </section>

  <section style="max-width:1200px; margin:0 auto; padding:8px 32px 56px;">
    <iframe src={`${pdf}#view=FitH`} title="VolnLabs Pitch Deck" style="width:100%; height:82vh; border:1px solid rgba(249,248,243,0.14); border-radius:16px; background:#1a1a1c;"></iframe>
  </section>

</Base>
