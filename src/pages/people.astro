---
import Base from '../layouts/Base.astro';

const values = [
  { n: '01', title: 'Cross-discipline by default', body: 'Neuroscientists, systems engineers, and roboticists work in the same room on the same questions.' },
  { n: '02', title: 'Small teams, real ownership', body: 'Every researcher owns problems end to end — from hypothesis to prototype to publication.' },
  { n: '03', title: 'Build to understand', body: 'We learn by building systems that run, fail, and get measured — not by theory alone.' },
];
const roles = [
  { title: 'Systems Researcher — Verified Runtimes', program: 'AxiomOS', type: 'Full-time' },
  { title: 'Real-Time Kernel Engineer', program: 'AxiomOS', type: 'Full-time' },
  { title: 'Robotics Safety Engineer', program: 'AxiomOS', type: 'Full-time' },
  { title: 'Research Internships', program: 'AxiomOS', type: 'Seasonal' },
];
const collaborators = ['Universities', 'Independent researchers', 'Robotics companies', 'Systems researchers', 'Graduate students', 'Open-source contributors'];
---
<Base title="People" bgColor="#F9F8F3">

  <!-- HEADER -->
  <section style="position:relative; overflow:hidden; border-bottom:1px solid rgba(10,10,11,0.08);">
    <div style="position:absolute; top:-200px; left:-120px; width:560px; height:560px; border-radius:50%; background:radial-gradient(circle at 50% 50%, rgba(225,210,243,0.8) 0%, rgba(225,210,243,0) 68%); pointer-events:none;"></div>
    <div style="max-width:1200px; margin:0 auto; padding:80px 32px 60px; position:relative;">
      <div style="font-size:11px; letter-spacing:0.2em; text-transform:uppercase; color:#054FF0;">People</div>
      <h1 style="font-family:'Bricolage Grotesque', sans-serif; font-weight:600; font-size:clamp(34px, 5.4vw, 68px); line-height:1.0; letter-spacing:-0.015em; margin:18px 0 0; max-width:17ch;">A small lab, asking large questions<span style="color:#054FF0;">.</span></h1>
      <p style="font-size:15px; line-height:1.75; color:rgba(10,10,11,0.7); max-width:60ch; margin:24px 0 0;">VolnLabs is an independent research laboratory in its founding year. We're assembling a team around AxiomOS — safe, adaptive robotics systems — and collaborating widely beyond it.</p>
    </div>
  </section>

  <!-- FOUNDER
  <section style="background:#F9F8F3;">
    <div style="max-width:1200px; margin:0 auto; padding:80px 32px 0;">
      <div style="font-size:11px; letter-spacing:0.2em; text-transform:uppercase; color:#054FF0;">[ 00 ] — Founder</div>
      <div style="margin-top:28px; background:#fff; border:1px solid rgba(10,10,11,0.1); border-radius:20px; padding:36px; display:flex; align-items:center; gap:40px; box-shadow:0 12px 30px rgba(10,10,11,0.04);">
        <div style="width:72px; height:72px; border-radius:50%; background:#DDE7FE; display:flex; align-items:center; justify-content:center; font-family:'Bricolage Grotesque', sans-serif; font-size:28px; color:#054FF0; flex:none;">U</div>
        <div style="flex:1;">
          <div style="font-family:'Bricolage Grotesque', sans-serif; font-size:32px; line-height:1;">Utkarsh Maurya</div>
          <div style="font-size:12.5px; color:rgba(10,10,11,0.55); margin-top:6px;">Founder · VolnLabs</div>
        </div>
        <div style="display:flex; gap:12px; flex-wrap:wrap;">
          <a href="mailto:projects.utkarshmaurya@gmail.com" class="contact-chip">✉ projects.utkarshmaurya@gmail.com</a>
          <a href="https://linkedin.com/in/utkarsh_maurya_connect" target="_blank" rel="noopener" class="contact-chip">in linkedin</a>
          <a href="https://x.com/gilfoyle_v2" target="_blank" rel="noopener" class="contact-chip">𝕏 @gilfoyle_v2</a>
        </div>
      </div>
    </div>
  </section> -->

  <!-- HOW WE WORK -->
  <section style="background:#F9F8F3;">
    <div style="max-width:1200px; margin:0 auto; padding:80px 32px;">
      <div style="font-size:11px; letter-spacing:0.2em; text-transform:uppercase; color:#054FF0;">[ 01 ] — How we work</div>
      <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:18px; margin-top:30px;">
        {values.map(v => (
          <div style="background:#fff; border:1px solid rgba(10,10,11,0.08); border-radius:20px; padding:26px; min-height:190px; box-shadow:0 12px 30px rgba(10,10,11,0.04);">
            <div style="font-family:'Bricolage Grotesque', sans-serif; font-size:34px; line-height:1; color:rgba(10,10,11,0.28);">{v.n}</div>
            <div style="font-family:'Bricolage Grotesque', sans-serif; font-size:26px; line-height:1.05; margin-top:16px;">{v.title}</div>
            <p style="font-size:13px; line-height:1.65; color:rgba(10,10,11,0.68); margin:12px 0 0;">{v.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- OPEN ROLES -->
  <section style="background:#F0E8F9;">
    <div style="max-width:1200px; margin:0 auto; padding:80px 32px;">
      <div style="display:flex; justify-content:space-between; align-items:flex-end; gap:24px; flex-wrap:wrap;">
        <div>
          <div style="font-size:11px; letter-spacing:0.2em; text-transform:uppercase; color:#054FF0;">[ 02 ] — Open positions</div>
          <h2 style="font-family:'Bricolage Grotesque', sans-serif; font-weight:600; font-size:clamp(26px, 4vw, 43px); line-height:1.0; margin:16px 0 0;">Join the founding team.</h2>
        </div>
        <div style="font-size:12.5px; color:rgba(10,10,11,0.6); max-width:34ch; line-height:1.6;">We hire for curiosity and rigor over credentials. Don't see your role? Write to us anyway.</div>
      </div>
      <div style="margin-top:32px; border-top:1px solid rgba(10,10,11,0.16);">
        {roles.map(r => (
          <a href="/contact" class="role-row">
            <div style="font-family:'Bricolage Grotesque', sans-serif; font-size:25px; line-height:1.1;">{r.title}</div>
            <div style="font-size:11px; letter-spacing:0.1em; text-transform:uppercase; color:rgba(10,10,11,0.6);">{r.program}</div>
            <div style="justify-self:end; font-size:10.5px; letter-spacing:0.1em; text-transform:uppercase; color:#054FF0;">{r.type} →</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- COLLABORATORS -->
  <section style="background:#F9F8F3;">
    <div style="max-width:1200px; margin:0 auto; padding:80px 32px;">
      <div style="font-size:11px; letter-spacing:0.2em; text-transform:uppercase; color:#054FF0;">[ 03 ] — We collaborate with</div>
      <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:14px 32px; margin-top:24px;">
        {collaborators.map(c => (
          <div style="display:flex; justify-content:space-between; align-items:center; padding:16px 0; border-bottom:1px solid rgba(10,10,11,0.12); font-size:14px;"><span>{c}</span><span style="color:#054FF0;">+</span></div>
        ))}
      </div>
    </div>
  </section>

</Base>

<style>
  .contact-chip {
    text-decoration: none;
    font-size: 11.5px;
    background: #F0E8F9;
    border-radius: 999px;
    padding: 8px 14px;
    color: rgba(10,10,11,0.78);
  }
  .contact-chip:hover { background: #DDE7FE; }
  .role-row {
    text-decoration: none;
    color: inherit;
    display: grid;
    grid-template-columns: 1fr 200px 130px;
    gap: 24px;
    align-items: center;
    padding: 22px 0;
    border-bottom: 1px solid rgba(10,10,11,0.12);
  }
  .role-row:hover { background: rgba(255,255,255,0.4); }
</style>
