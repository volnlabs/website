---
import Base from '../layouts/Base.astro';

const links = [
  { label: 'Research', href: '/research' },
  { label: 'Publications', href: '/publications' },
  { label: 'Benchmarks', href: '/benchmarks' },
  { label: 'Open source', href: '/opensource' },
];
---
<Base title="Page not found" description="The page you're looking for doesn't exist." bgColor="#F9F8F3">

  <section style="position:relative; overflow:hidden; min-height:72vh; display:flex; align-items:center;">
    <div style="position:absolute; top:-160px; right:-120px; width:520px; height:520px; border-radius:50%; background:radial-gradient(circle at 50% 50%, rgba(221,231,254,0.9) 0%, rgba(221,231,254,0) 68%); pointer-events:none;"></div>

    <div class="nf-wrap" style="max-width:1200px; margin:0 auto; padding:96px 32px; position:relative;">
      <div style="font-size:11px; letter-spacing:0.2em; text-transform:uppercase; color:#054FF0;">Error 404</div>

      <h1 style="font-family:'Bricolage Grotesque', sans-serif; font-weight:600; font-size:clamp(64px, 16vw, 200px); line-height:0.9; letter-spacing:-0.03em; margin:14px 0 0;">404<span style="color:#054FF0;">.</span></h1>

      <p style="font-size:14.5px; line-height:1.75; color:rgba(10,10,11,0.7); max-width:46ch; margin:22px 0 0;">This page slipped out of distribution. The link may be broken, or the page may have moved.</p>

      <a href="/" style="display:inline-flex; align-items:center; gap:12px; margin-top:30px; text-decoration:none; background:#0a0a0b; color:#F9F8F3; border-radius:16px; padding:16px 22px;">
        <span style="width:9px; height:9px; border-radius:999px; background:#DCFC73;"></span>
        <span style="font-family:'Bricolage Grotesque', sans-serif; font-size:20px;">Back to home →</span>
      </a>

      <div style="margin-top:40px;">
        <div style="font-size:10.5px; letter-spacing:0.16em; text-transform:uppercase; color:rgba(10,10,11,0.45);">Or explore</div>
        <div style="display:flex; flex-wrap:wrap; gap:8px; margin-top:14px;">
          {links.map(l => (
            <a href={l.href} style="font-size:11.5px; text-decoration:none; background:#F0E8F9; border-radius:999px; padding:8px 14px; color:rgba(10,10,11,0.78);">{l.label}</a>
          ))}
        </div>
      </div>
    </div>
  </section>

</Base>

<style>
  @media (max-width:640px) {
    .nf-wrap { padding-left:20px !important; padding-right:20px !important; }
  }
</style>
